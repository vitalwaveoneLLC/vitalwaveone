SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# === MAPS (Live Tracking) ===
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# === BACKEND ONLY ===
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
NODE_ENV=development
