# Database
DATABASE_URL=postgresql://user:password@host/database

# Google Maps API (for truck tracking and customer locations)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Meta WhatsApp Business API
META_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
META_ACCESS_TOKEN=your_whatsapp_business_account_token

# Stripe (for payments)
VITE_STRIPE_PUBLIC_KEY=pk_live_or_pk_test_key
STRIPE_SECRET_KEY=sk_live_or_sk_test_key

# Cloudflare R2 (file storage)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=vitalwaveone

# App Configuration
VITE_API_URL=https://your-domain.com
VITE_APP_NAME=VitalWaveOne
