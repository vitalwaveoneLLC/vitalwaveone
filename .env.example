# VitalWave Wholesale Platform Configuration
# Domain: vitalwaveone.com | Version: 2.0.0
# Copy to .env.local and fill in actual values

# ═══════════════════════════════════════════════════════════════
# APPLICATION
# ═══════════════════════════════════════════════════════════════
VITE_APP_NAME=VitalWave Wholesale Platform
VITE_APP_DOMAIN=vitalwaveone.com
NODE_ENV=development

# ═══════════════════════════════════════════════════════════════
# API CONFIGURATION
# ═══════════════════════════════════════════════════════════════
VITE_API_BASE_URL=http://localhost:5173/api
VITE_API_TIMEOUT=30000

# ═══════════════════════════════════════════════════════════════
# PAYMENT PROCESSING (Stripe)
# ═══════════════════════════════════════════════════════════════
VITE_STRIPE_PUBLIC_KEY=pk_test_YOUR_KEY
STRIPE_SECRET_KEY=sk_test_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET

# ═══════════════════════════════════════════════════════════════
# DATABASE (Neon PostgreSQL)
# ═══════════════════════════════════════════════════════════════
DATABASE_URL=postgresql://user:password@neon.tech:5432/vitalwaveone
DATABASE_REPLICA_URL=postgresql://user:password@neon.tech:5432/vitalwaveone_replica

# ═══════════════════════════════════════════════════════════════
# AUTHENTICATION & SECURITY
# ═══════════════════════════════════════════════════════════════
JWT_SECRET=your_jwt_secret_min_32_characters_long_here
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d
OTP_EXPIRY=10m
ADMIN_LOGOUT_TIMEOUT=600000
ORDERING_LOGOUT_TIMEOUT=900000

# ═══════════════════════════════════════════════════════════════
# MULTI-FACTOR AUTHENTICATION
# ═══════════════════════════════════════════════════════════════
MFA_ENABLED=true
FACE_RECOGNITION_ENABLED=true
OTP_SERVICE=twilio

# ═══════════════════════════════════════════════════════════════
# EMAIL SERVICE (Gmail SMTP)
# ═══════════════════════════════════════════════════════════════
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password
MAIL_FROM_ADDRESS=noreply@vitalwaveone.com
MAIL_FROM_NAME=VitalWave Platform

# ═══════════════════════════════════════════════════════════════
# STORAGE (AWS S3)
# ═══════════════════════════════════════════════════════════════
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
AWS_BUCKET=vitalwaveone-storage

# ═══════════════════════════════════════════════════════════════
# MAPS & LOCATION SERVICES
# ═══════════════════════════════════════════════════════════════
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
LOCATION_TRACKING_ENABLED=true
GPS_UPDATE_INTERVAL=30000

# ═══════════════════════════════════════════════════════════════
# LOGGING & MONITORING
# ═══════════════════════════════════════════════════════════════
LOG_LEVEL=info
SENTRY_DSN=https://your-dsn@sentry.io
ANALYTICS_ENABLED=true

# ═══════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════
FEATURE_INVENTORY_MANAGEMENT=true
FEATURE_TRUCK_TRACKING=true
FEATURE_IRS_REPORTS=true
FEATURE_FINANCIAL_DASHBOARD=true
FEATURE_SUPPLIER_MANAGEMENT=true
FEATURE_DATA_BACKUP=true

# ═══════════════════════════════════════════════════════════════
# CORS & DEPLOYMENT
# ═══════════════════════════════════════════════════════════════
CORS_ORIGIN=http://localhost:5173
ALLOWED_ORIGIN=http://localhost:5173
VERCEL_URL=https://vitalwaveone.vercel.app
